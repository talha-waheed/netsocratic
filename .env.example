# Copy this file to .env and fill in your values.

# Required: OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional overrides
OPENAI_MODEL=gpt-4o
# Set to 1-5 seconds if long experiment runs hit OpenAI 429 rate limits.
OPENAI_MIN_SECONDS_BETWEEN_REQUESTS=0
MAX_CLARIFY_ROUNDS=5
NUM_CANDIDATES=3
KB_DIR=agents/knowledge-base
TOPO_DIR=../cs598_LMZ_final/topo
RESULTS_DIR=results
